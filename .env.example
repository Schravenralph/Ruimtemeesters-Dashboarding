# Server
PORT=5022
NODE_ENV=development

# Database (6432 maps to 5432 inside Docker)
# DB_PASSWORD: generate with `openssl rand -base64 32 | tr -d '+/=' | head -c 32`.
# Do not commit. docker-compose.yml requires it; postgres + app both read it.
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:6432/dashboarding
DB_HOST=localhost
DB_PORT=6432
DB_NAME=dashboarding
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=24h

# Client
VITE_DEV_PORT=3303
VITE_API_PROXY_TARGET=http://localhost:5022

# Server
PORT=5022
NODE_ENV=development

# Database (6432 maps to 5432 inside Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:6432/dashboarding
DB_HOST=localhost
DB_PORT=6432
DB_NAME=dashboarding
DB_USER=postgres
DB_PASSWORD=postgres

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=24h

# Client
VITE_DEV_PORT=3303
VITE_API_PROXY_TARGET=http://localhost:5022
